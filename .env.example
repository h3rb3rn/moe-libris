# moe-libris — Environment Configuration

# -- Database --
POSTGRES_PASSWORD=change-me-in-production

# -- Neo4j (Global Knowledge Graph) --
NEO4J_PASSWORD=change-me-in-production

# -- Identity --
# Unique ID for this Libris instance (used in federation handshakes)
LIBRIS_NODE_ID=my-libris-instance
# Public URL where other Libris servers can reach this instance
LIBRIS_PUBLIC_URL=https://libris.example.org
# Admin API key for managing this Libris instance
LIBRIS_ADMIN_KEY=change-me-in-production

# -- Registry --
# Git repository URL for the moe-libris-registry (server discovery)
REGISTRY_REPO_URL=https://github.com/moe-sovereign/moe-libris-registry.git
# How often to sync the registry (seconds)
REGISTRY_SYNC_INTERVAL=3600

# -- Logging --
LOG_LEVEL=info
