# moe-nexus — Environment Configuration

# -- Database --
POSTGRES_PASSWORD=change-me-in-production

# -- Neo4j (Global Knowledge Graph) --
NEO4J_PASSWORD=change-me-in-production

# -- Identity --
# Unique ID for this Nexus instance (used in federation handshakes)
NEXUS_NODE_ID=my-nexus-instance
# Public URL where other Nexus servers can reach this instance
NEXUS_PUBLIC_URL=https://nexus.example.org
# Admin API key for managing this Nexus instance
NEXUS_ADMIN_KEY=change-me-in-production

# -- Registry --
# Git repository URL for the moe-nexus-registry (server discovery)
REGISTRY_REPO_URL=https://github.com/moe-sovereign/moe-nexus-registry.git
# How often to sync the registry (seconds)
REGISTRY_SYNC_INTERVAL=3600

# -- Logging --
LOG_LEVEL=info
